{
  "name": "qforge-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + playwright-bdd end-to-end tests for the qforge web demo",
  "scripts": {
    "pretest": "bddgen",
    "test": "playwright test",
    "test:ui": "bddgen && playwright test --ui",
    "test:headed": "bddgen && playwright test --headed",
    "test:debug": "bddgen && PWDEBUG=1 playwright test",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "playwright-bdd": "^9.2.0",
    "typescript": "^6.0.3"
  }
}
